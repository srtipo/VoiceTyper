# VoiceTyper — variables de entorno opcionales
# Copiá este archivo a ".env" y editá los valores que quieras override.
# El archivo ".env" está en .gitignore: nunca se sube al repo.
#
# Precedencia (mayor a menor):
#   1. Variable de entorno del sistema (para CI / override global)
#   2. Archivo .env junto a VoiceTyper.exe
#   3. settings.json en %LOCALAPPDATA%\VoiceTyper\
#   4. Defaults hardcodeados en el código

## Idioma default para transcripción (es, en, pt, fr, auto)
VT_LANGUAGE=es

## Modelo default de Whisper (tiny, base, small, medium)
VT_MODEL=small

## Carpeta donde se guardan los modelos descargados
## Default: %LOCALAPPDATA%\VoiceTyper\models
# VT_MODEL_DIR=C:\ruta\personalizada\models

## Nivel de log (Trace, Debug, Information, Warning, Error)
VT_LOG_LEVEL=Information

## Carpeta de logs
## Default: %LOCALAPPDATA%\VoiceTyper\logs
# VT_LOG_DIR=C:\ruta\personalizada\logs

## Directorio de trabajo (opcional, sólo para debug)
# VT_WORK_DIR=

# ----------------------------------------------------------------------------
# API keys — Reservado para futuro (MVP usa Whisper local, sin internet)
# Cuando se implemente fallback a cloud, descomentar y poner valor real acá.
# NUNCA commitear el .env con valores reales.
# ----------------------------------------------------------------------------

# VT_OPENAI_API_KEY=
# VT_GROQ_API_KEY=

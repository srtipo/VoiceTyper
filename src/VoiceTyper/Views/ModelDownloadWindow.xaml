<Window x:Class="VoiceTyper.Views.ModelDownloadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceTyper — Descargando modelo"
        Width="460" Height="220"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        Topmost="True"
        ShowInTaskbar="True">
    <StackPanel Margin="16">
        <TextBlock Text="Descargando modelo Whisper (small, ~460 MB). Esto puede tardar varios minutos según tu conexión."
                   TextWrapping="Wrap" />
        <ProgressBar Name="DownloadProgress"
                     Minimum="0" Maximum="100"
                     Height="22"
                     Margin="0,12,0,0"
                     Value="{Binding DownloadPercent}" />
        <TextBlock Name="StatusText"
                   Text="{Binding DownloadStatus}"
                   HorizontalAlignment="Stretch"
                   Margin="0,8,0,0" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Name="CancelButton"
                    Content="Cancelar"
                    Width="100" Height="28" />
        </StackPanel>
    </StackPanel>
</Window>

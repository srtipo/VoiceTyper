        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VoiceTyper"
        mc:Ignorable="d"
        Title="VoiceTyper" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="VoiceTyper" FontSize="32" FontWeight="Bold" HorizontalAlignment="Center" />
            <TextBlock Text="Dictado por voz global para Windows" FontSize="14" Margin="0,8,0,0" HorizontalAlignment="Center" />
            <TextBlock Text="(Fase 1 — placeholder de UI)" FontSize="12" Foreground="Gray" Margin="0,16,0,0" HorizontalAlignment="Center" />
            <TextBlock Text="Cerrá esta ventana para volver al system tray." FontSize="12" Foreground="Gray" Margin="0,24,0,0" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
